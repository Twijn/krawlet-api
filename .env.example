# Database
DATABASE_URL=mysql://user:password@localhost:3306/krawlet

# Express Server
PORT=3000
# RATE_LIMIT_IGNORE_IPS=192.168.1.100,10.0.0.1

# Discord Bot
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_client_id_here

# Discord Webhook Notifications
KROMER_WEBHOOK=your_discord_webhook_url_here

# ReconnectedChat
CHAT_LICENSE=your_rcc_license_key_here
PREFIX=

# Krawlet Kromer Wallet
KRAWLET_PKEY=your_private_key_here

# Admin Dashboard (optional)
# Set a secure password to enable the admin dashboard at /admin
ADMIN_PASSWORD=your_secure_admin_password_here
ADMIN_ALLOWED_IPS=127.0.0.1